# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/mydb"

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (https://dashboard.stripe.com/apikeys)
# Secret key — server only; used by auth.service.js for Checkout Sessions
STRIPE_SECRET_KEY=sk_test_...
# Publishable key — use on the frontend with Stripe.js / Elements
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Frontend URL for Stripe Checkout success/cancel redirects
CLIENT_URL=http://localhost:5173

# SMTP (Nodemailer) — password reset OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Raven <your-email@gmail.com>"

# CORS (production only) — comma-separated extra allowed origins
# CORS_ALLOWED_ORIGINS=https://your-app.netlify.app,https://app.example.com
# Set to true to allow any https://*.netlify.app deploy preview
# CORS_ALLOW_NETLIFY=true
