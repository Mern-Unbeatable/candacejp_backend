# Server Configuration
PORT=3000
# Environment name: development | production (DEV / PROD)
NODE_ENV=development

# ---------------------------------------------------------------------------
# Postgres connection (split config)
# Host/URL + username live in environment variables.
# Password comes from AWS Secrets Manager (see AWS section below).
# For local-only fallback you may set DATABASE_PASSWORD here, or use DATABASE_URL.
# ---------------------------------------------------------------------------
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
# Local fallback only — prefer AWS Secrets Manager in shared/deployed envs
# DATABASE_PASSWORD=your-local-db-password
# Optional: require | no-verify | disable
# DATABASE_SSLMODE=no-verify

# Legacy fallback (optional). Used only when DATABASE_HOST / DATABASE_USER
# are not set. Prefer the split variables above.
# DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Frontend URL for Stripe Checkout success/cancel redirects (also used for CORS)
CLIENT_URL=http://localhost:5173

# Production example:
# NODE_ENV=production
# CLIENT_URL=https://candacejp.maktechgroup.tech
# CORS_ALLOWED_ORIGINS=https://candacejp.maktechgroup.tech

# SMTP (Nodemailer) — password reset OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Raven <your-email@gmail.com>"

# CORS (production only) — comma-separated extra allowed origins
# CORS_ALLOWED_ORIGINS=https://your-app.netlify.app,https://app.example.com
# CORS_ALLOW_NETLIFY=true

# ---------------------------------------------------------------------------
# AWS Secrets Manager — Postgres password only
# Secret name is stored in environment variables.
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_SECRET_NAME=raven/backend/database-password
# Local credentials (not needed on ECS / IAM task role):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# Secret value options:
# 1) Plain text password
# 2) JSON: { "DATABASE_PASSWORD": "your-db-password" }
