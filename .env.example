# Server Configuration
PORT=3000
# Environment name: development | production (DEV / PROD)
NODE_ENV=development

# ---------------------------------------------------------------------------
# Credential precedence:
#   1) AWS Secrets Manager (if AWS_SECRET_NAME is set) — WINS on conflicts
#   2) This .env / Coolify env — fills anything AWS does not provide
# Client aliases in AWS JSON also work: RDS_Endpoint, RDS_UN, RDS_PW_Secret
# ---------------------------------------------------------------------------
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
# Local fallback only when AWS does not supply password
# DATABASE_PASSWORD=your-local-db-password
# Optional: require | no-verify | disable
# DATABASE_SSLMODE=no-verify

# Legacy fallback (optional). Used only when split vars are incomplete.
# DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Frontend URL for Stripe Checkout success/cancel redirects (also used for CORS)
CLIENT_URL=http://localhost:5173

# Production example:
# NODE_ENV=production
# CLIENT_URL=https://candacejp.maktechgroup.tech
# CORS_ALLOWED_ORIGINS=https://candacejp.maktechgroup.tech

# SMTP (Nodemailer) — password reset OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Raven <your-email@gmail.com>"

# CORS (production only) — comma-separated extra allowed origins
# CORS_ALLOWED_ORIGINS=https://your-app.netlify.app,https://app.example.com
# CORS_ALLOW_NETLIFY=true

# ---------------------------------------------------------------------------
# AWS Secrets Manager
# Put AWS_SECRET_NAME in Coolify/.env. Secret JSON can hold any app keys.
# If the same key exists in AWS and .env, AWS wins.
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_SECRET_NAME=raven/backend/config
# Local credentials (not needed on ECS / IAM task role):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# Secret JSON examples:
# 1) Client-style config (password via nested RDS secret):
#    { "RDS_Endpoint":"....rds.amazonaws.com", "RDS_UN":"postgres",
#      "RDS_PW_Secret":"rds!db-....", "JWT_ACCESS_SECRET":"...", ... }
# 2) RDS-managed secret directly: { "username","password","host","port",... }
# 3) Plain-text secret: whole value used as DATABASE_PASSWORD
